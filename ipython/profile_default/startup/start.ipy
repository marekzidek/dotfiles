import json, dataclasses
from pydantic import BaseModel
from collections.abc import Mapping, Sequence

def to_plain(o, _seen=None):
    """
    Recursively convert o into only dicts, lists, and primitives:
      • BaseModel (v2 or v1) → dict
      • dataclass           → dict
      • Mapping            → dict
      • Sequence           → list
      • Any object with __dict__ → that dict
      • Fallback           → repr(o)
    """
    if _seen is None:
        _seen = set()
    oid = id(o)
    if oid in _seen:
        return f"<circular:{type(o).__name__}>"
    _seen.add(oid)

    # primitives
    if o is None or isinstance(o, (bool, int, float, str)):
        return o

    # Pydantic v2: .model_dump(); v1: .dict()
    if isinstance(o, BaseModel):
        if hasattr(o, "model_dump"):
            data = o.model_dump()
        else:
            data = o.dict()
        return to_plain(data, _seen)

    # dataclass
    if dataclasses.is_dataclass(o):
        return to_plain(dataclasses.asdict(o), _seen)

    # mapping (dict-like)
    if isinstance(o, Mapping):
        return {str(k): to_plain(v, _seen) for k, v in o.items()}

    # sequences (list/tuple/set)
    if isinstance(o, Sequence) and not isinstance(o, (str, bytes, bytearray)):
        return [to_plain(v, _seen) for v in o]

    # any other object with __dict__
    if hasattr(o, "__dict__"):
        return to_plain(o.__dict__, _seen)

    # fallback: repr
    return repr(o)


def show_schema(obj):
    """
    Infer a JSON Schema from any Python dict/list.
    Usage in IPython:
      schema = get_schema(my_dict)
    """
    b = SchemaBuilder()
    b.add_object(to_plain(obj))
    import json; print(json.dumps(b.to_schema(), indent=2))
    return

def get_schema(obj):
    """
    Infer a JSON Schema from any Python dict/list.
    Usage in IPython:
      schema = get_schema(my_dict)
    """
    b = SchemaBuilder()
    b.add_object(obj)
    import json; print(json.dumps(b.to_schema(), indent=2))
    return b.to_schema()

def extract_imports(source_code):
    import_lines = []
    for line in source_code.splitlines():
        line = line.strip()
        if line.startswith("import ") or line.startswith("from "):
            import_lines.append(line)
    return import_lines

