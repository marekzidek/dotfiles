# Complex, but handles multiline decorators
def extract_functions(source_code):
    lines = source_code.split('\n')
    results = []
    block = []
    in_decorator = False
    open_parens = 0
    i = 0
    n = len(lines)
    while i < n:
        line = lines[i]
        stripped = line.lstrip()
        # Start decorator block
        if stripped.startswith('@'):
            if block:
                # Save previous block if any
                results.append('\n'.join(block))
                block = []
            in_decorator = True
            open_parens = stripped.count('(') - stripped.count(')')
            block.append(line)
            i += 1
            # Continue collecting decorator lines if parentheses are not closed
            while in_decorator and i < n:
                next_line = lines[i]
                block.append(next_line)
                open_parens += next_line.count('(') - next_line.count(')')
                if open_parens <= 0 and next_line.strip().endswith(')'):
                    in_decorator = False
                i += 1
            # Now expect the function def
            if i < n and lines[i].lstrip().startswith('def '):
                block.append(lines[i])
                i += 1
                # Collect function body (indented lines)
                while i < n and (lines[i].startswith(' ') or lines[i].startswith('\t') or lines[i].strip() == ''):
                    block.append(lines[i])
                    i += 1
                results.append('\n'.join(block))
                block = []
        # Start function with no decorator
        elif stripped.startswith('def '):
            if block:
                results.append('\n'.join(block))
                block = []
            block.append(line)
            i += 1
            while i < n and (lines[i].startswith(' ') or lines[i].startswith('\t') or lines[i].strip() == ''):
                block.append(lines[i])
                i += 1
            results.append('\n'.join(block))
            block = []
        else:
            i += 1
    # Add any remaining block (in case file ends mid-function)
    if block:
        results.append('\n'.join(block))
    return [b for b in results if b.strip()]  # Remove empty blocks

def get_function_name(fn_src):
    # Find the first line that starts with 'def '
    for line in fn_src.splitlines():
        match = re.match(r'^\s*def\s+([a-zA-Z_][\w]*)\s*\(', line)
        if match:
            return match.group(1)
    return '<unknown function name>'

def safe_load_functions_and_imports(filepath, g=None):
    g = g or globals()
    source = Path(filepath).read_text()

    # First: Try all imports
    print("📌 Note: As of now, it is expected that the REPL runs in the same folder as the script you're just loading")
    print("🔄 Processing imports...")
    for line in extract_imports(source):
        try:
            exec(line, g)
            print(f"✅ Imported: {line}")
        except Exception:
            print(f"❌ Failed to import: {line}\n{traceback.format_exc()}")

    # Then: Try all functions
    print("\n🔄 Processing functions...")
    for fn_src in extract_functions(source):
        try:
            exec(fn_src, g)
            name = get_function_name(fn_src)
            print(f"✅ Loaded function: {name}")
        except Exception:
            print(f"❌ Failed to load function:\n{traceback.format_exc()}")
