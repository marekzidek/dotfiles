cmd copy_to_clipboard ${{
      repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || true
      if [ -n "$repo_root" ]; then
          printf '%s' "${f#$repo_root/}" | pbcopy
      else
          printf '%s' "$f" | pbcopy
      fi
  }}
map <c-c> copy_to_clipboard
