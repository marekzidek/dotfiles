# define a custom 'open' command
# This command is called when current file is not a directory. You may want to
# use either file extensions and/or mime types here. Below uses an editor for
# text files and a file opener for the rest.
cmd open ${{
    case $(file --mime-type $f -b) in
	text/*) $EDITOR $fx;;
	application/json) $EDITOR $fx;;
	application/octet-stream) $EDITOR $fx;;
	# *) for f in $fx; do setsid $OPENER $f > /dev/null 2> /dev/null & done;;
	*) for f in $fx; do $OPENER $f; done;;
	# *) $OPENER $fx;;
    esac
}}

map P play
# define a custom 'Play' command
# This command works for csv, json, pickle and xlsx files
# It just opens an ipython session with the file loaded for playing / analysing
#cmd Play ${{
#    case $f in
#        *.xlsx) ipython -i -c "hi = pd.read_excel($fx)";;
#    esac
#}}
        
cmd play ${{

    case $f in
        *.xlsx)  ipython -i -c "hi = pd.read_excel('$f')";;
	*.pickle)  ipython -i -c "with open('$f', 'rb') as f: import pickle; hi = pickle.load(f)";;
	*.pkl)  ipython -i -c "with open('$f', 'rb') as f: import pickle; hi = pickle.load(f)";;
	*.json)  ipython -i -c "with open('$f', 'r') as f: import json; import jsons; hi = jsons.load(json.load(f))";;
	*.tsv)  ipython -i -c "hi = pd.read_csv('$f', sep='\\t')";;
	*.csv)  ipython -i -c "hi = pd.read_csv('$f')";;
	*.parquet)  ipython -i -c "hi = pd.read_parquet('$f')";; 
    esac
}}

# define a custom 'Viz' command
# This command works for csv xlsx files
# It just opens visidata to see this dataframe
cmd viz ${{
    case $f in
        *.xlsx)  visidata $f;;
	*.csv)  visidata $f;;
	*.tsv)  visidata $f;;
	*.parquet)  visidata $f;;
    esac
}}
map V viz


